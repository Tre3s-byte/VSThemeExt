  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#3A3F58", "fontStyle": "italic" }
    },
    {
      "name": "Keywords & Control Flow",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#7ABFCF" }
    },
    {
      "name": "Classes & Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type",
        "entity.other.inherited-class"
      ],
      "settings": { "foreground": "#F3C677" }
    },
    {
      "name": "Functions & Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": { "foreground": "#7ABFCF" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#C8D0E0" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#81F8EC" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#E8A0BF" }
    },
    {
      "name": "String escape sequences",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#F3C677" }
    },
    {
      "name": "Numbers & Constants",
      "scope": ["constant.numeric", "constant.language", "constant.other"],
      "settings": { "foreground": "#F8BE64" }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property"
      ],
      "settings": { "foreground": "#81F8EC" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#5A4F7A" }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "punctuation.definition.block"
      ],
      "settings": { "foreground": "#4A4565" }
    },
    {
      "name": "Tags (HTML/JSX)",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": { "foreground": "#E8A0BF" }
    },
    {
      "name": "Tag attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#F3C677" }
    },
    {
      "name": "CSS property names",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#81F8EC" }
    },
    {
      "name": "CSS values",
      "scope": ["support.constant.property-value.css"],
      "settings": { "foreground": "#E8A0BF" }
    },
    {
      "name": "CSS selectors",
      "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#F3C677" }
    },
    {
      "name": "Dart — support.class",
      "scope": ["support.class.dart"],
      "settings": { "foreground": "#F3C677" }
    },
    {
      "name": "Dart — operators/punctuation",
      "scope": [
        "keyword.operator.dart",
        "storage.type.function.arrow.dart",
        "punctuation.separator.key-value.dart"
      ],
      "settings": { "foreground": "#5A4F7A" }
    },
    {
      "name": "Python decorators",
      "scope": ["entity.name.function.decorator.python"],
      "settings": { "foreground": "#F3C677", "fontStyle": "italic" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": { "foreground": "#E87070" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#F3C677",
    "type": "#F3C677",
    "interface": "#F3C677",
    "struct": "#F3C677",
    "enum": "#F3C677",
    "enumMember": "#F8BE64",
    "function": "#7ABFCF",
    "method": "#7ABFCF",
    "parameter": "#81F8EC",
    "property": "#81F8EC",
    "property.static": "#F3C677",
    "variable": "#C8D0E0",
    "variable.readonly": "#C8D0E0",
    "keyword": "#7ABFCF",
    "string": "#E8A0BF",
    "number": "#F8BE64",
    "comment": { "foreground": "#3A3F58", "italic": true },
    "decorator": "#F3C677",
    "namespace": "#C8A0D8"
  }
}
