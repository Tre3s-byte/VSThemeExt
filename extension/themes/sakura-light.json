  "tokenColors": [
    { "name": "Comments", "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#9BAAB8", "fontStyle": "italic" } },
    { "name": "Keywords", "scope": ["keyword", "keyword.control", "keyword.other", "storage.type", "storage.modifier"], "settings": { "foreground": "#7EC4E0" } },
    { "name": "Classes & Types", "scope": ["entity.name.type", "entity.name.class", "support.class", "support.type", "entity.other.inherited-class"], "settings": { "foreground": "#C07A20", "fontStyle": "bold" } },
    { "name": "Functions", "scope": ["entity.name.function", "support.function", "meta.function-call"], "settings": { "foreground": "#5AAECC" } },
    { "name": "Variables", "scope": ["variable", "variable.other"], "settings": { "foreground": "#1E2330" } },
    { "name": "Parameters", "scope": ["variable.parameter"], "settings": { "foreground": "#4A7A9B" } },
    { "name": "Strings", "scope": ["string", "string.quoted"], "settings": { "foreground": "#B86A3A" } },
    { "name": "String escapes", "scope": ["constant.character.escape", "string.regexp"], "settings": { "foreground": "#C07A20" } },
    { "name": "Numbers", "scope": ["constant.numeric", "constant.language", "constant.other"], "settings": { "foreground": "#7050A0" } },
    { "name": "Properties", "scope": ["variable.other.property", "variable.other.object.property", "support.variable.property"], "settings": { "foreground": "#4A7A9B" } },
    { "name": "Operators", "scope": ["keyword.operator"], "settings": { "foreground": "#A898C0" } },
    { "name": "Punctuation", "scope": ["punctuation", "punctuation.separator", "punctuation.terminator", "punctuation.accessor", "punctuation.definition.block"], "settings": { "foreground": "#B0B8CC" } },
    { "name": "Tags", "scope": ["entity.name.tag", "meta.tag"], "settings": { "foreground": "#B86A3A" } },
    { "name": "Tag attributes", "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#C07A20" } },
    { "name": "CSS props", "scope": ["support.type.property-name.css"], "settings": { "foreground": "#4A7A9B" } },
    { "name": "CSS values", "scope": ["support.constant.property-value.css"], "settings": { "foreground": "#B86A3A" } },
    { "name": "CSS selectors", "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"], "settings": { "foreground": "#C07A20" } },
    { "name": "Dart class", "scope": ["support.class.dart"], "settings": { "foreground": "#C07A20", "fontStyle": "bold" } },
    { "name": "Dart operators", "scope": ["keyword.operator.dart", "storage.type.function.arrow.dart", "punctuation.separator.key-value.dart"], "settings": { "foreground": "#A898C0" } },
    { "name": "Python decorators", "scope": ["entity.name.function.decorator.python"], "settings": { "foreground": "#C07A20", "fontStyle": "italic" } },
    { "name": "Invalid", "scope": ["invalid"], "settings": { "foreground": "#C84040" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class":            { "foreground": "#C07A20", "bold": true },
    "type":             { "foreground": "#C07A20", "bold": true },
    "interface":        { "foreground": "#C07A20", "bold": true },
    "struct":           { "foreground": "#C07A20", "bold": true },
    "enum":             { "foreground": "#C07A20", "bold": true },
    "enumMember":       "#7050A0",
    "function":         "#5AAECC",
    "method":           "#5AAECC",
    "parameter":        "#4A7A9B",
    "property":         "#4A7A9B",
    "property.static":  { "foreground": "#C07A20", "bold": true },
    "variable":         "#1E2330",
    "variable.readonly": "#1E2330",
    "keyword":          "#7EC4E0",
    "string":           "#B86A3A",
    "number":           "#7050A0",
    "comment":          { "foreground": "#9BAAB8", "italic": true },
    "decorator":        { "foreground": "#C07A20", "italic": true },
    "namespace":        "#7050A0"
  }
}
